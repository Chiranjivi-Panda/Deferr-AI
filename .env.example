# ─────────────────────────────────────────────────────────────────────
# Last-Minute Life Saver — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────

# Google Gemini API Key (REQUIRED for AI features)
# Get a free key at: https://aistudio.google.com/apikey
# 1. Go to the link above and sign in with your Google account
# 2. Click "Create API Key"
# 3. Copy the key and paste it below
GEMINI_API_KEY=your_gemini_api_key_here

# Calendar provider: "mock" (default) or "google" (Phase 4, requires OAuth)
# The app runs fully on "mock" with no Google account needed.
CALENDAR_PROVIDER=mock

# Server port (default: 3001)
SERVER_PORT=3001
